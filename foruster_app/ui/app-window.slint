import { VerticalBox, TextEdit } from "std-widgets.slint";

export component AppWindow inherits Window {
    resize-border-width: 0mm;
    title: "Foruster";
    min-width: 800px;
    min-height: 600px;

    in property <string> dynamicText;
    
    VerticalBox {
        TextEdit {
            text: dynamicText;
        }
    }
}
