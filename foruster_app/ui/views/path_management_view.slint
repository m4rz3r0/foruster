import { PathList, PathListAdapter } from "../components/index.slint";
import { VerticalBox, HorizontalBox, LineEdit, Button, ScrollView } from "std-widgets.slint";
import { Styling } from "../global.slint";

export component PathManagementView {
    callback browse-for-path();
    callback start-analysis();
    pure callback redundancies-count <=> PathListAdapter.redundancies-count;
    
    property <string> new-path: "";

    pure function check-redundancies() -> bool {
        redundancies-count() > 0
    }
    
    VerticalBox {
        padding: 10px;
        
        Text {
            text: @tr("Rutas a Analizar");
            font-weight: 800;
            font-size: 18px;
            color: Styling.text;
        }
        
        Text {
            text: @tr("Seleccione los directorios que serán analizados");
            font-size: 14px;
            color: Styling.text-secondary;
        }
        
        HorizontalBox {
            spacing: 10px;
            
            LineEdit {
                placeholder-text: @tr("Ruta a analizar...");
                text <=> new-path;
                width: parent.width - 200px;
            }
            
            Button {
                text: @tr("Explorar...");
                clicked => { browse-for-path(); }
                width: 90px;
            }
            
            Button {
                text: @tr("Añadir");
                clicked => {
                    if (new-path != "") {
                        PathListAdapter.add-path(new-path);
                        new-path = "";
                        check-redundancies();
                    }
                }
                width: 80px;
            }
        }
        
        Rectangle {
            height: 1px;
            background: Styling.border;
        }
        
        Text {
            text: @tr("Rutas Actuales");
            font-weight: 600;
            font-size: 16px;
            color: Styling.text;
        }

        PathList {
            paths: PathListAdapter.paths;
            update-path(index, path) => { PathListAdapter.update-path(index, path); check-redundancies(); }
            remove-path(index) => { PathListAdapter.remove-path(index); check-redundancies(); }
        }
        
        if (PathListAdapter.paths-count() == 0) : Text {
            text: @tr("Aún no hay rutas añadidas. Seleccione directorios para comenzar el análisis.");
            color: Styling.text-muted;
        }
        
        
        
        if (check-redundancies()) : Rectangle {
            background: Styling.warning-bg;
            border-radius: 4px;
            padding: 10px;
            
            HorizontalBox {
                Text {
                    text: @tr("Se han detectado ") + redundancies-count() + @tr(" rutas redundantes. Revise las rutas añadidas.");
                    color: Styling.warning-dark;
                }
            }
        }
        
        Rectangle {
            height: 1px;
            background: Styling.border;
        }

        HorizontalBox {
            alignment: end;
            Button {
                text: @tr("Analizar");
                primary: true;
                enabled: PathListAdapter.paths-count() > 0 && redundancies-count() == 0;
                clicked => { start-analysis(); }
            }
        }
    }
}