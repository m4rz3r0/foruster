import { DiskList, DiskListAdapter } from "../components/disk_list.slint";
import { Button, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component DiskListView {
    visible: true;
    callback analyze-disks();
    callback update_disks <=> DiskListAdapter.update_disks;
    callback update_num_selected_disks <=> DiskListAdapter.update_num_selected_disks;
    update_disk_timer := Timer {
        interval: 3s;
        running: parent.visible;
        triggered => {
            update_disks();
        }
    }

    VerticalBox {
        padding: 20px;
        spacing: 10px;
        VerticalLayout {
            Text {
                text: @tr("Análisis de discos");
                font-weight: 800;
                font-size: 24px;
            }

            Text {
                text: @tr("Seleccione los discos que desea analizar:");
                font-size: 14px;
            }
        }

        DiskList {
            disks: DiskListAdapter.disks;
            toggle(index) => {
                DiskListAdapter.toggle_disk_checked(index);
                update_num_selected_disks();
            }
        }

        HorizontalLayout {
            alignment: center;
            Button {
                primary: true;
                text: @tr("Analizar discos");
                enabled: DiskListAdapter.num_selected_disks > 0;
                clicked => {
                    analyze-disks();
                }
            }
        }
    }
}
