import { PathList, PathListAdapter } from "../components/index.slint";
import { VerticalBox, HorizontalBox, LineEdit, Button, ScrollView } from "std-widgets.slint";
// Importar el nuevo global PathAnalysisState
import { Styling, PathAnalysisState } from "../global.slint"; 
import { LoadingIndicator } from "../components/LoadingIndicator.slint";

export component PathManagementView {
    callback start-path-analysis(string);
    
    property <string> new-path: "";
    property <int> redundant-paths: 0;

    // Eliminadas las propiedades locales de estado de carga
    // in-out property <bool> path_analysis_running: false;
    // in-out property <string> path_analysis_message: "Analizando rutas...";
    // in-out property <float> path_analysis_progress: 0.0;
    // in-out property <bool> path_analysis_indeterminate: true;

    pure function check-redundancies() -> bool {
        redundant-paths > 0
    }
    
    VerticalBox {
        padding: 10px;
        
        indicator := LoadingIndicator {
            // Usar el global PathAnalysisState
            is_loading: PathAnalysisState.running;
            message: PathAnalysisState.message;
            progress: PathAnalysisState.progress;
            indeterminate: PathAnalysisState.indeterminate;
        }

        Text {
            text: @tr("Rutas a Analizar");
            font-weight: 800;
            font-size: 24px;
            color: Styling.text;
        }
        
        Text {
            text: @tr("Seleccione los directorios que serán analizados");
            font-size: 14px;
            color: Styling.text-secondary;
        }
        
        HorizontalBox {
            spacing: 10px;
            
            path-text := LineEdit {
                placeholder-text: @tr("Ruta a analizar...");
                text <=> new-path;
                width: parent.width - 200px;
                enabled: false;
            }
            
            Button {
                text: @tr("Explorar...");
                clicked => {
                    path-text.text = PathListAdapter.browse-for-path();
                }
                width: 90px;
            }
            
            Button {
                text: @tr("Añadir");
                clicked => {
                    if (new-path != "") {
                        PathListAdapter.add-path(new-path);
                        new-path = "";
                        redundant-paths = PathListAdapter.redundant-count();
                    }
                }
                width: 80px;
            }
        }
        
        Rectangle {
            height: 1px;
            background: Styling.border;
        }
        
        Text {
            text: @tr("Rutas Actuales");
            font-weight: 600;
            font-size: 16px;
            color: Styling.text;
        }

        PathList {
            paths: PathListAdapter.paths;
            update-path(index, path) => {
                PathListAdapter.update-path(index, path);
                redundant-paths = PathListAdapter.redundant-count();
            }
            remove-path(index) => {
                PathListAdapter.remove-path(index);
                redundant-paths = PathListAdapter.redundant-count();
            }
        }
        
        if (PathListAdapter.path-count() == 0) : Text {
            text: @tr("Aún no hay rutas añadidas. Seleccione directorios para comenzar el análisis.");
            color: Styling.text-muted;
        }
        
        if (check-redundancies()) : Rectangle {
            background: Styling.warning-bg;
            border-radius: 4px;
            padding: 10px;
            
            HorizontalBox {
                Text {
                    text: @tr("Se han detectado ") + PathListAdapter.redundant-count() + @tr(" rutas redundantes. Revise las rutas añadidas.");
                    color: Styling.warning-dark;
                }
            }
        }
        
        Rectangle {
            height: 1px;
            background: Styling.border;
        }

        HorizontalBox {
            alignment: end;
            Button {
                text: @tr("Analizar");
                primary: true;
                // Usar PathAnalysisState.running para el estado enabled
                enabled: PathListAdapter.path-count() > 0 && !check-redundancies() && !PathAnalysisState.running;
                clicked => {
                    if (PathListAdapter.path-count() > 0) {
                       // Corregido: Acceder a la propiedad 'paths' del adaptador y luego al campo 'path' del primer elemento.
                       root.start-path-analysis(PathListAdapter.paths[0].path);
                    }
                }
            }
        }
    }
}