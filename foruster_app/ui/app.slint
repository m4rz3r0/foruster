import { DiskListView } from "index.slint";
import { WindowSettings } from "global.slint";
import { VerticalBox } from "std-widgets.slint";
import { DiskAnalysisView } from "views/disk_analysis.slint";

export { DiskListAdapter } from "components/index.slint";

enum Pages {
    DiskList,
    DiskAnalysis,
    ProfileSelection,
}

export component App inherits Window {
    min-width: WindowSettings.min-window-width;
    min-height: WindowSettings.min-window-height;
    title: WindowSettings.title;
    icon: WindowSettings.icon;

    property <Pages> current_page: DiskList;
    
    VerticalLayout {
        padding: 20px;
        spacing: 16px;

        disk_list_view := DiskListView {
            visible: current_page == Pages.DiskList;
            analyze-disks => {
                current_page = Pages.DiskAnalysis;
            }
        }
    
        disk_analysis_view := DiskAnalysisView {
            visible: current_page == Pages.DiskAnalysis;
            on_disk_analyzed => {
                current_page = Pages.ProfileSelection;
            }
        }
    }
}
