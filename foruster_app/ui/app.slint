import { DiskListView, DiskAnalysisView, PathManagementView } from "index.slint";
import { WindowSettings } from "global.slint";
import { VerticalBox } from "std-widgets.slint";

export { DiskListAdapter } from "components/index.slint";

enum Page {
    DiskList,
    PathManagement,
    DiskAnalysis,
    ProfileSelection,
}

export component App inherits Window {
    min-width: WindowSettings.min-window-width;
    min-height: WindowSettings.min-window-height;
    title: WindowSettings.title;
    icon: WindowSettings.icon;

    property <Page> current-page: PathManagement;
    
    VerticalLayout {
        padding: 20px;
        spacing: 16px;

        if current-page == Page.DiskList : DiskListView {
            analyze-disks => {
                current_page = Page.PathManagement;
            }
        }
    
        if current-page == Page.DiskAnalysis : DiskAnalysisView {
            disk-analyzed => {
                current-page = Page.ProfileSelection;
            }
        }

        if current-page == Page.PathManagement : PathManagementView {}
    }
}
