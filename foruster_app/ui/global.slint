import { Palette } from "std-widgets.slint";

export global WindowSettings {
    out property <length> min-window-width: 800px;
    out property <length> min-window-height: 600px;
    out property <string> title: @tr("Foruster");
    out property <image> icon: @image-url("assets/icon.png");
}

export global ProfileCardIcons {
    out property <image> app: @image-url("assets/profile_icons/app.svg");
    out property <image> audio: @image-url("assets/profile_icons/audio.svg");
    out property <image> image: @image-url("assets/profile_icons/image.svg");
    out property <image> model: @image-url("assets/profile_icons/model.svg");
    out property <image> text: @image-url("assets/profile_icons/text.svg");
    out property <image> video: @image-url("assets/profile_icons/video.svg");
}

export global Styling {
    out property <brush> background: Palette.background;
    out property <brush> alternate-background: Palette.alternate-background;
    out property <brush> primary: Palette.accent-background;
    out property <brush> secondary: Palette.accent-foreground;
    out property <brush> accent: Palette.selection-background;
    out property <brush> text: Palette.foreground;
    out property <brush> text-secondary: Palette.alternate-foreground;
    out property <brush> border: Palette.border;
    out property <brush> hover: Palette.control-background;
    out property <brush> disabled: Palette.control-foreground;

    // New derived colors
    out property <brush> background-deeper: background.darker(5%);
    out property <brush> background-deepest: background.darker(10%);
    out property <brush> background-weaker: background.brighter(5%);
    out property <brush> background-weakest: background.brighter(10%);

    out property <brush> primary-deeper: primary.darker(5%);
    out property <brush> primary-deepest: primary.darker(10%);
    out property <brush> primary-weaker: primary.brighter(5%);
    out property <brush> primary-weakest: primary.brighter(10%);

    out property <brush> border-deeper: border.darker(5%);
    out property <brush> border-deepest: border.darker(10%);
    out property <brush> border-weaker: border.brighter(5%);
    out property <brush> border-weakest: border.brighter(10%);

    out property <brush> primary-light: primary.brighter(20%);
    out property <brush> primary-dark: primary.darker(20%);
    out property <brush> accent-light: accent.brighter(15%);
    out property <brush> accent-dark: accent.darker(15%);
    out property <brush> text-muted: text.transparentize(40%);
    out property <brush> border-strong: border.darker(20%);
    out property <brush> hover-active: hover.darker(10%);
    
    // Warning colors
    out property <brush> warning: #ff9800;
    out property <brush> warning-light: warning.brighter(15%);
    out property <brush> warning-dark: warning.darker(15%);
    out property <brush> warning-bg: warning.transparentize(85%);
    out property <brush> warning-border: warning.transparentize(60%);

    // App colors
    out property <brush> app-primary: #bc573b;
}

// Nuevo global para el estado del análisis de rutas
export global PathAnalysisState {
    in-out property <bool> running: false;
    in-out property <string> message: ""; // Inicialmente vacío o un mensaje neutral
    in-out property <float> progress: 0.0;
    in-out property <bool> indeterminate: true;
    // Podrías añadir aquí una propiedad para el resultado si quieres mostrarlo globalmente
    // in-out property <PathAnalysisResultModel> result; // Necesitarías definir PathAnalysisResultModel
}