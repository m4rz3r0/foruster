import { VerticalBox } from "std-widgets.slint";
import { Styles } from "../styles.slint";
import { ProfileMenuBridge } from "../blocks/bridges.slint";

/// A single slice of the chart using Normalized Coordinates (ViewBox).
component CircularProfileItem inherits Rectangle {
    // -------------------------------------------------------------------------
    // Properties
    // -------------------------------------------------------------------------
    in property <string> title;
    in property <image> icon;
    in property <color> base-color;
    in-out property <bool> selected;

    in property <angle> start-angle;
    in property <angle> sweep-angle;

    callback clicked <=> touch.clicked;

    width: 100%;
    height: 100%;
    background: transparent;

    // -------------------------------------------------------------------------
    // Geometry
    // -------------------------------------------------------------------------

    // Angles
    private property <angle> end-angle: root.start-angle + root.sweep-angle;
    private property <angle> mid-angle: root.start-angle + (root.sweep-angle / 2);

    // ViewBox Coordinates (200x200)
    private property <float> p2-x: 100 + 98 * cos(root.start-angle);
    private property <float> p2-y: 100 + 98 * sin(root.start-angle);
    private property <float> p3-x: 100 + 98 * cos(root.end-angle);
    private property <float> p3-y: 100 + 98 * sin(root.end-angle);

    // Content Position (Absolute Layout)
    // 1. Math Center: (0.45 inner + 0.95 outer) / 2 = 0.70
    // We use 0.70 to place items exactly in the visual middle of the band.
    private property <length> content-r: (min(root.width, root.height) / 2) * 0.70;

    private property <length> content-x: root.width / 2 + root.content-r * cos(root.mid-angle);
    private property <length> content-y: root.height / 2 + root.content-r * sin(root.mid-angle);

    // -------------------------------------------------------------------------
    // Visuals
    // -------------------------------------------------------------------------

    // 1. Slice Shape
    slice-shape := Path {
        width: 100%;
        height: 100%;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 200;
        viewbox-height: 200;

        MoveTo {
            x: 100;
            y: 100;
        }

        LineTo {
            x: root.p2-x;
            y: root.p2-y;
        }

        ArcTo {
            x: root.p3-x;
            y: root.p3-y;
            radius-x: 98;
            radius-y: 98;
            sweep: true;
            large-arc: root.sweep-angle > 180deg;
        }

        Close { }

        fill: root.base-color;
        stroke: Styles.palette.window-bg;
        stroke-width: 2px;

        animate fill {
            duration: 200ms;
            easing: ease-in-out;
        }
    }

    // 2. Content Overlay
    // Dynamic width based on text length causes jitter/offset in polar layouts.
    content-box := Rectangle {
        // Calculate a safe width based on the arc length approx.
        // 130px fits nicely for 6-8 slices on typical screens.
        width: 130px;
        height: 80px; // Enough for icon + text

        // Perfectly centered on the calculated polar coordinate
        x: root.content-x - self.width / 2;
        y: root.content-y - self.height / 2;

        background: transparent;

        VerticalLayout {
            alignment: center; // This handles the internal centering
            spacing: 4px;

            // Icon Wrapper
            // Use a Rectangle to reserve space and avoid layout shifts during animation
            Rectangle {
                height: 40px;
                background: transparent;

                Image {
                    source: root.icon;
                    colorize: Colors.white;
                    image-fit: contain;

                    // Center explicitly within the wrapper
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;

                    // Selection Animation
                    property <length> size: root.selected ? 38px : 30px;
                    width: self.size;
                    height: self.size;

                    animate width, height {
                        duration: 200ms;
                        easing: ease-out-back;
                    }
                }
            }

            Text {
                text: root.title;
                color: Colors.white;
                font-size: Styles.sizes.font;
                font-weight: 700;
                horizontal-alignment: center;
                wrap: word-wrap; // Safety if text is too long
            }
        }
    }

    // 3. Hit Area
    touch := TouchArea {
        x: root.content-x - 45px;
        y: root.content-y - 45px;
        width: 90px;
        height: 90px;
        mouse-cursor: pointer;
    }

    states [
        active-selected when root.selected: {
            slice-shape.fill: root.base-color.brighter(0.2);
            slice-shape.stroke-width: 4px;
        }
        hover when touch.has-hover && !root.selected: {
            slice-shape.fill: root.base-color.darker(0.1);
        }
        inactive when !root.selected: {
            slice-shape.fill: root.base-color.with-alpha(0.85);
        }
    ]
}

export component ProfileListPage {
    callback start-profile-analysis();

    function update-button-enabled-status() {
        analyzeButton.enabled = ProfileMenuBridge.count-selected-profiles() > 0;
    }

    property <angle> sector-angle: 360deg / max(1, ProfileMenuBridge.profiles.length);

    VerticalBox {
        padding: Styles.sizes.p-xl;
        spacing: Styles.sizes.s-lg;

        // Title Header
        VerticalLayout {
            vertical-stretch: 0;
            Text {
                text: @tr("Perfiles de análisis");
                font-weight: Styles.weights.bold;
                font-size: Styles.sizes.font * 1.5;
                color: Styles.palette.primary-fg;
            }

            Text {
                text: @tr("Selecciona los tipos de archivos que deseas investigar.");
                color: Styles.palette.window-alter-fg;
                font-size: Styles.sizes.font;
            }
        }

        // Main Chart Area
        chart-area := Rectangle {
            vertical-stretch: 1;

            // Pie Slices
            for profile[i] in ProfileMenuBridge.profiles: CircularProfileItem {
                title: profile.label;
                icon: ProfileMenuBridge.icon_source_to_icon(profile.icon-source);
                base-color: profile.bg-color;

                start-angle: (i * root.sector-angle) - 90deg;
                sweep-angle: root.sector-angle;

                selected: profile.selected;

                clicked => {
                    profile.selected = !profile.selected;
                    update-button-enabled-status();
                }
            }

            // Central "Hole" Mask (Donut Effect)
            Rectangle {
                width: min(parent.width, parent.height) * 0.45;
                height: self.width;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                border-radius: self.width / 2;
                background: Styles.palette.window-bg;
            }

            // Central Button
            analyzeButton := Rectangle {
                property <length> base-diameter: min(parent.width, parent.height) * 0.35;
                property <float> scale-factor: 1.0;

                width: self.base-diameter * self.scale-factor;
                height: self.base-diameter * self.scale-factor;

                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;

                border-radius: self.width / 2;

                property <bool> enabled: false;

                background: analyzeButton.enabled ? Styles.palette.primary-bg : Styles.palette.window-alter-bg;
                border-width: 4px;
                border-color: Styles.palette.window-bg;

                drop-shadow-blur: 15px;
                drop-shadow-color: analyzeButton.enabled ? Styles.palette.primary-bg.with-alpha(0.4) : transparent;
                drop-shadow-offset-y: 5px;

                animate background, width, height {
                    duration: 200ms;
                    easing: ease-in-out;
                }

                touch-area := TouchArea {
                    mouse-cursor: analyzeButton.enabled ? pointer : default;
                    clicked => {
                        if (analyzeButton.enabled) {
                            start-profile-analysis();
                        }
                    }
                }

                VerticalLayout {
                    alignment: center;
                    Text {
                        text: analyzeButton.enabled ? @tr("ANALIZAR") : @tr("SELECCIONA");
                        font-weight: 900;
                        font-size: Styles.sizes.font * 1.1;
                        color: analyzeButton.enabled ? Colors.white : Styles.palette.disabled-fg;
                        horizontal-alignment: center;
                    }

                    if analyzeButton.enabled: Text {
                        text: @tr("INICIAR");
                        font-size: Styles.sizes.font * 0.7;
                        font-weight: 600;
                        color: Colors.white.with-alpha(0.8);
                        horizontal-alignment: center;
                    }
                }

                states [
                    hover when touch-area.has-hover && analyzeButton.enabled: {
                        scale-factor: 1.05;
                        background: Styles.palette.primary-bg.brighter(0.1);
                    }
                    pressed when touch-area.pressed && analyzeButton.enabled: {
                        scale-factor: 0.95;
                        background: Styles.palette.primary-bg.darker(0.1);
                    }
                ]
            }
        }
    }
}
