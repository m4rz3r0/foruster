import {
    VerticalBox,
    HorizontalBox,
    LineEdit,
    Button,
    ScrollView,
    ListView,
} from "std-widgets.slint";
import { Styles } from "../styles.slint";
import { PathManagementBridge } from "../blocks/bridges.slint";

component PathItem {
    in-out property <string> path;
    in-out property <bool> redundant: false;
    in-out property <string> redundancy-message: "";

    callback remove;
    callback change-path(string);

    VerticalBox {
        alignment: start;
        spacing: 2px;

        HorizontalBox {
            padding: 5px;
            spacing: 10px;

            Rectangle {
                width: 4px;
                background: redundant ? Styles.palette.warn-fg : transparent;
            }

            Text {
                text: path;
                vertical-alignment: center;
                color: redundant ? Styles.palette.warn-fg : Styles.palette.window-fg;
            }

            HorizontalBox {
                padding-left: Styles.sizes.p-md;
                spacing: Styles.sizes.s-md;
                alignment: end;

                Button {
                    text: @tr("Modify");
                    width: 100px;
                    clicked => {
                        change-path(PathManagementBridge.browse-path())
                    }
                }

                Button {
                    text: @tr("Delete");
                    width: 100px;
                    clicked => {
                        remove();
                    }
                }
            }
        }

        if (redundant): Rectangle {
            background: Styles.palette.warn-bg;
            border-width: 1px;
            border-color: Styles.palette.element-border;
            border-radius: 4px;
            height: 30px;

            HorizontalBox {
                padding: 5px;
                Text {
                    text: redundancy-message;
                    color: Styles.palette.window-alter-fg;
                    font-size: Styles.sizes.font * 0.75;
                }
            }
        }
    }
}

export component PathManagementPage {
    callback start-path-analysis();

    property <string> new-path: "";
    property <int> redundant-paths: 0;

    pure function check-redundancies() -> bool {
        redundant-paths > 0
    }

    VerticalBox {
        spacing: Styles.sizes.s-lg;
        padding: Styles.sizes.p-xl;

        VerticalLayout {
            vertical-stretch: 0;

            Text {
                text: @tr("Path Analysis");
                font-weight: Styles.weights.bold;
                font-size: Styles.sizes.font * 1.5;
                color: Styles.palette.window-fg;
            }

            Text {
                text: @tr("Select the directories to be analyzed");
                font-size: Styles.sizes.font;
                color: Styles.palette.window-alter-fg;
            }

            HorizontalBox {
                spacing: Styles.sizes.s-md;

                path-text := LineEdit {
                    placeholder-text: @tr("Path to analyze...");
                    text <=> new-path;
                    enabled: false;
                }

                Button {
                    text: @tr("Browse...");
                    clicked => {
                        path-text.text = PathManagementBridge.browse-path();
                    }
                    width: 100px;
                }

                Button {
                    text: @tr("Add");
                    clicked => {
                        if (new-path != "") {
                            PathManagementBridge.add-path(new-path);
                            PathManagementBridge.check-paths();
                            new-path = "";
                            redundant-paths = PathManagementBridge.redundant-count();
                        }
                    }
                    width: 100px;
                }
            }

            Rectangle {
                height: 1px;
                background: Styles.palette.element-border;
            }
        }

        Text {
            text: @tr("Current Paths");
            font-weight: 600;
            font-size: 16px;
            color: Styles.palette.window-fg;
        }

        VerticalLayout {
            vertical-stretch: 1;
            ListView {
                for path_data[index] in PathManagementBridge.paths: VerticalLayout {
                    padding: Styles.sizes.p-md;

                    PathItem {
                        path: path_data.path;
                        redundant: path_data.redundant;
                        redundancy-message: path_data.redundancy-message;

                        change-path(new_path_value) => {
                            PathManagementBridge.update_path(index, new_path_value);
                            PathManagementBridge.check-paths();
                            redundant-paths = PathManagementBridge.redundant-count();
                        }

                        remove => {
                            PathManagementBridge.remove_path(index);
                            PathManagementBridge.check-paths();
                            redundant-paths = PathManagementBridge.redundant-count();
                        }
                    }
                }
            }
        }

        VerticalLayout {
            vertical-stretch: 0;
            if (PathManagementBridge.paths.length == 0): Text {
                text: @tr("No paths added yet. Select directories to start analysis.");
                color: Styles.palette.window-alter-fg;
            }

            if (check-redundancies()): Rectangle {
                background: Styles.palette.warn-bg;
                border-radius: 4px;

                HorizontalBox {
                    Text {
                        text: @tr("Detected ") + redundant-paths + @tr(" redundant paths. Review added paths.");
                        color: Styles.palette.warn-fg;
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: Styles.palette.element-border;
            }

            HorizontalBox {
                alignment: end;
                Button {
                    text: @tr("Analyze");
                    primary: true;
                    enabled: PathManagementBridge.paths.length > 0 && !check-redundancies();
                    clicked => {
                        root.start-path-analysis();
                    }
                }
            }
        }
    }
}
