import { ProfileCardIcons } from "../globals.slint";

export struct Disk {
    name: string,
    size: string,
    serial: string,
    partitions: int,
    mounted-partitions: int,
    interface: string,
    selected: bool
}

export global DiskListBridge {
    in-out property <[Disk]> disks: [
        {
           name: "Disk 1",
           size: 1024,
           serial: "123456",
           interface: "SSD",
        },
        {
           name: "Disk 2",
           size: 2048,
           serial: "654321",
           interface: "HDD",
        },
        {
          name: "Disk 1",
          size: 1024,
          serial: "123456",
          interface: "SSD",
        },
        {
          name: "Disk 2",
          size: 2048,
          serial: "654321",
          interface: "HDD",
        },
   ];
    
    pure callback num-selected-disks() -> int;
    pure callback check-for-changes() -> bool;

    callback refresh-disks;
}

export struct Path {
    path: string,
    redundant: bool,
    redundancy-message: string,
    volume_id: string
}

export global PathManagementBridge {
    in-out property <[Path]> paths;

    pure callback redundant-count() -> int;
    pure callback browse-path() -> string;

    callback get-start-paths();
    callback add-path(string);
    callback remove-path(int);
    callback update-path(int, string);

    callback check-paths();
}

export struct Profile {
    label: string,
    icon-source: string,
    bg-color: color,
    selected: bool
}

export global ProfileMenuBridge {
    in-out property <[Profile]> profiles: [
        { label: "Aplicaciones", bg_color: #644661, icon_source: "app", selected: false },
        { label: "Audio", bg_color: #86883D, icon_source: "audio", selected: false },
        { label: "Imágenes", bg_color: #5F7E81, icon_source: "image", selected: false },
        { label: "Modelos", bg_color: #CA672E, icon_source: "model", selected: false },
        { label: "Textos", bg_color: #9D6C79, icon_source: "text", selected: false },
        { label: "Vídeos", bg_color: #48705D, icon_source: "video", selected: false },
    ];

    pure callback count-selected-profiles() -> int;

    public pure function icon_source_to_icon(icon_source: string) -> image {
        if (icon_source == "app") {
            ProfileCardIcons.app
        } else if (icon_source == "audio") {
            ProfileCardIcons.audio
        } else if (icon_source == "image") {
            ProfileCardIcons.image
        } else if (icon_source == "model") {
            ProfileCardIcons.model
        } else if (icon_source == "text") {
            ProfileCardIcons.text
        } else if (icon_source == "video") {
            ProfileCardIcons.video
        } else {
            ProfileCardIcons.app
        }
    }
}

export struct File {
    name: string,
    path: string,
    type: string,
    size: string,
    match-score: string,
    profile: string,
    thumbnail: image,
}

export global AnalysisResultBridge {
